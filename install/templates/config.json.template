{
  "$schema": "https://raw.githubusercontent.com/vladm3105/aidoc-flow-ci/ci/v2.5.0/schemas/ai-review-config-v2.schema.json",
  "version": 2,
  "_note": "ENFORCED (resolved from the TRUST-CONFIG repo, operations@main by default, NOT the PR branch): trust.ai_review, trust.auto_fix, litellm.model, auto_merge.repos, autofix.enabled, autofix.max_fix_rounds. A PR cannot self-enable autofix. See DECISIONS.md CI-0005 + PLAN-012.",
  "litellm": {
    "model": "ai-reviewer"
  },
  "trust": {
    "ai_review": ["${CODEOWNER_HANDLE}"],
    "auto_fix":  []
  },
  "governance": {
    "locked_paths": [".github/", "governance/", "templates/ai-review/"],
    "code_owners": ["@${CODEOWNER_HANDLE}"],
    "require_human_review": false
  },
  "composition": {
    "required": true,
    "carry_forward_on_skip_label": true
  },
  "auto_merge": {
    "enabled": true,
    "spec_paths_blocked": ["framework/", "spec/"]
  },
  "autofix": {
    "enabled": false,
    "max_fix_rounds": 2
  }
}
